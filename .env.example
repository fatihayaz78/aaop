# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS (S3 log reading — log_analyzer)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=ssport-datastream

# Mock Data / Ingestion
MOCK_DATA_BASE_PATH=/Users/fatihayaz/Documents/Projects/AAOP/aaop-mock-data
