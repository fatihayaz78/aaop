# AAOP — Captain logAR Environment Variables
# Copy to .env and fill in values

# LLM
ANTHROPIC_API_KEY=

# Auth
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ADMIN_PASSWORD=change_this_in_production

# Database paths
SQLITE_PATH=./data/sqlite/platform.db
DUCKDB_PATH=./data/duckdb/analytics.duckdb
